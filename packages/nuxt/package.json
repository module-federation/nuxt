{
  "name": "@module-federation/nuxt",
  "version": "0.0.1",
  "type": "module",
  "description": "Nuxt module for Module Federation using @module-federation/vite",
  "main": "./dist/federation.mjs",
  "module": "./dist/federation.mjs",
  "types": "./dist/federation.d.mts",
  "repository": {
    "type": "git",
    "url": "https://github.com/module-federation/nuxt",
    "directory": "packages/nuxt"
  },
  "bugs": {
    "url": "https://github.com/module-federation/nuxt/issues"
  },
  "homepage": "https://github.com/module-federation/nuxt#readme",
  "keywords": [
    "nuxt",
    "module federation",
    "microfrontend"
  ],
  "exports": {
    ".": {
      "types": "./dist/federation.d.mts",
      "import": "./dist/federation.mjs",
      "default": "./dist/federation.mjs"
    },
    "./shared-strategy": {
      "types": "./dist/shared-strategy.d.mts",
      "import": "./dist/shared-strategy.mjs",
      "default": "./dist/shared-strategy.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "pack:dry": "npm pack --dry-run",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "dependencies": {
    "@module-federation/vite": "1.16.4",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/schema": "^4.4.8"
  },
  "peerDependencies": {
    "nuxt": "^4.4.8"
  },
  "devDependencies": {
    "@types/node": "24",
    "nuxt": "4.4.8",
    "tsdown": "^0.21.0",
    "vue-tsc": "3.2.2"
  }
}
