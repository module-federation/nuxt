{
  "name": "@module-federation/nuxt",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "pack:dry": "npm pack --dry-run",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/federation.mjs",
  "module": "./dist/federation.mjs",
  "types": "./dist/federation.d.mts",
  "exports": {
    ".": {
      "types": "./dist/federation.d.mts",
      "import": "./dist/federation.mjs",
      "default": "./dist/federation.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@module-federation/vite": "1.16.4",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/schema": "^4.4.8"
  },
  "peerDependencies": {
    "nuxt": "^4.4.8"
  },
  "devDependencies": {
    "@types/node": "24",
    "nuxt": "4.4.8",
    "tsdown": "^0.21.0",
    "vue-tsc": "3.2.2"
  }
}
