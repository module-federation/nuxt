{
  "name": "nuxt-mf",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "preview": "turbo run preview",
    "dev": "turbo run dev",
    "dev:host": "turbo run dev --filter=nuxt-host",
    "dev:remote": "turbo run dev --filter=nuxt-remote",
    "format": "prettier --write \"**/*.{ts,vue,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
